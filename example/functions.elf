expanded := strings.expand({ "src", "vendor" }, "'/I'.(' ')*")
elf.assert(expanded == "/Isrc /Ivendor", "strings.expand produced the wrong result")

build := fun() {
	ret bob.build({
		targets = {},
		options = {
			workers = 1,
			verbosity = 0,
		},
	})
}

clean := fun() {
	ret 1
}

ret {
	build = build,
	clean = clean,
}
